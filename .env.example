# Configuración de Google Calendar API
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=tu_google_refresh_token_aqui

# Configuración de OpenAI API (Recomendado)
OPENAI_API_KEY=tu_openai_api_key_aqui

# Configuración de Gemini API (Alternativa)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Configuración del servidor
PORT=3001

# Web3Forms (envío de emails de reseñas) — https://web3forms.com
# 1. Ir a web3forms.com → poner tu email → confirmar → copiar la clave
# 2. Agregar esta variable en Vercel → Settings → Environment Variables
REACT_APP_WEB3FORMS_KEY=tu_access_key_aqui
